# --- MongoDB ---
MONGODB_URI=your_mongodb_uri_here

# --- Server ---
PORT=5000
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Public URL for links in emails and local file URLs (no trailing slash)
PUBLIC_BASE_URL=http://localhost:5000

# Frontend URL (CORS); optional for same-origin dev
CLIENT_URL=http://localhost:5173

# --- Email (Nodemailer) — optional; without SMTP, messages are logged only ---
EMAIL_FROM=onboarding@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# IT / admin notification for IT setup step
IT_TEAM_EMAIL=it@yourcompany.com
ADMIN_NOTIFY_EMAIL=

# --- Cloudinary (optional) — if unset, files stay in server/uploads ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed script (scripts/seed.js)
SEED_PASSWORD=ChangeMe123!
